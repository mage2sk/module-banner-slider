                $altText = !empty($slide['alt_text']) ? $slide['alt_text'] : __('Banner %1', $index + 1);
            ?>
            <div class="panth-banner-slide"
                 x-show="current === <?= (int)$index ?>"
                 <?php if ($effect === 'fade'): ?>
                     x-transition:enter="transition ease-out duration-[var(--banner-transition-speed,600)ms]"
                     x-transition:enter-start="opacity-0"
                     x-transition:enter-end="opacity-100"
                     x-transition:leave="transition ease-in duration-[var(--banner-transition-speed,600)ms]"
                     x-transition:leave-start="opacity-100"
                     x-transition:leave-end="opacity-0"
                 <?php else: ?>
                     x-transition:enter="transition ease-out duration-[var(--banner-transition-speed,600)ms]"
                     x-transition:enter-start="translate-x-full opacity-0"
                     x-transition:enter-end="translate-x-0 opacity-100"
                     x-transition:leave="transition ease-in duration-[var(--banner-transition-speed,600)ms]"
                     x-transition:leave-start="translate-x-0 opacity-100"
                     x-transition:leave-end="-translate-x-full opacity-0"
                 <?php endif; ?>
                 role="tabpanel"
                 aria-roledescription="slide"
                 aria-label="<?= $escaper->escapeHtmlAttr(__('Slide %1 of %2', $index + 1, $slideCount)) ?>"
            >
