                    <a href="<?= $escaper->escapeUrl($linkUrl) ?>" class="block relative w-full h-full">
                <?php endif; ?>

                <picture class="block w-full h-full">
                    <?php if (!empty($images['mobile'])): ?>
                        <source media="(max-width: 767px)" srcset="<?= $escaper->escapeUrl($images['mobile']) ?>">
