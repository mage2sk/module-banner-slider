    <?php if ($slideCount > 1): ?>
        <!-- Mobile controls bar: dots left + arrows right (below slider) -->
        <div class="panth-banner-controls">
            <div class="panth-banner-controls-dots">
                <?php for ($i = 0; $i < $slideCount; $i++): ?>
                    <button type="button"
                            class="panth-banner-controls-dot"
                            :class="current === <?= (int)$i ?> && 'panth-banner-controls-dot--active'"
                            @click="goTo(<?= (int)$i ?>)"
                            aria-label="<?= $escaper->escapeHtmlAttr(__('Slide %1', $i + 1)) ?>">
                    </button>
                <?php endfor; ?>
            </div>
            <div class="panth-banner-controls-arrows">
                <button type="button" @click="prev()" aria-label="<?= $escaper->escapeHtmlAttr(__('Previous')) ?>">
