</div>

<script>
    function panthBannerSlider(total, config) {
        return {
            current: 0,
            total: total,
            timer: null,
            touchStartX: 0,
            config: config,

            init() {
                if (this.config.autoplay && this.total > 1) {
                    this.startAutoplay();
                }
            },

            startAutoplay() {
                this.stopAutoplay();
                this.timer = setInterval(() => this.next(), this.config.autoplaySpeed || 5000);
            },

            stopAutoplay() {
                if (this.timer) {
                    clearInterval(this.timer);
                    this.timer = null;
                }
            },

            pause() {
                if (this.config.pauseOnHover) this.stopAutoplay();
            },

            resume() {
                if (this.config.autoplay && this.config.pauseOnHover) this.startAutoplay();
            },

            next() {
                if (this.config.loop) {
                    this.current = (this.current + 1) % this.total;
                } else {
                    this.current = Math.min(this.current + 1, this.total - 1);
                }
            },

            prev() {
                if (this.config.loop) {
                    this.current = (this.current - 1 + this.total) % this.total;
                } else {
                    this.current = Math.max(this.current - 1, 0);
                }
            },

            goTo(index) {
                this.current = index;
                if (this.config.autoplay) this.startAutoplay();
            },

            touchStart(e) {
                this.touchStartX = e.changedTouches[0].screenX;
            },

            touchEnd(e) {
                const diff = this.touchStartX - e.changedTouches[0].screenX;
                if (Math.abs(diff) > 50) {
                    diff > 0 ? this.next() : this.prev();
                    if (this.config.autoplay) this.startAutoplay();
                }
            },

            destroy() {
                this.stopAutoplay();
            }
        };
    }
</script>
