<?php
/**
 * Copyright © Panth Infotech. All rights reserved.
 * Banner Slider — Luma/RequireJS Version
 *
 * Vanilla JS slider — no Swiper dependency.
 * Uses CSS variables from theme-config.json for styling.
 *
 * @var $block \Panth\BannerSlider\Block\Widget\BannerSlider
 * @var $escaper \Magento\Framework\Escaper
 */

if (!$block->canDisplay()) {
    return;
}

$slides = $block->getSlides();
$uniqueId = $block->getUniqueId();
$helper = $block->getHelper();
$config = $block->getSliderConfig();
$slideCount = count($slides);
$showArrows = ($config['showArrows'] ?? true) && $slideCount > 1;
$showDots = ($config['showDots'] ?? true) && $slideCount > 1;
?>

<div class="panth-banner-slider"
     id="<?= $escaper->escapeHtmlAttr($uniqueId) ?>"
     data-mage-init='{"Panth_BannerSlider/js/banner-slider": <?= /* @noEscape */ $block->getSliderConfigJson() ?>}'
     role="region"
     aria-label="<?= $escaper->escapeHtmlAttr(__('Banner Slider')) ?>">
    <div class="panth-banner-track">
        <?php foreach ($slides as $index => $slide): ?>
            <?php
                $images = $helper->getResponsiveImages($slide);
                $contentHtml = $slide['content_html'] ?? '';
                $linkUrl = $slide['link_url'] ?? '';
                $hasLink = !empty($linkUrl) && $linkUrl !== '#';
                $altText = !empty($slide['alt_text']) ? $slide['alt_text'] : __('Banner %1', $index + 1);
            ?>
            <div class="panth-banner-slide" data-slide="<?= (int)$index ?>"
                 style="<?= $index !== 0 ? 'opacity:0; pointer-events:none;' : '' ?>">
                <?php if ($hasLink): ?>
                    <a href="<?= $escaper->escapeUrl($linkUrl) ?>" style="display:block;width:100%;height:100%;">
                <?php endif; ?>

                <picture style="display:block;width:100%;height:100%;">
                    <?php if (!empty($images['mobile'])): ?>
                        <source media="(max-width: 767px)" srcset="<?= $escaper->escapeUrl($images['mobile']) ?>">
                    <?php endif; ?>
                    <?php if (!empty($images['tablet'])): ?>
                        <source media="(min-width: 768px) and (max-width: 1023px)" srcset="<?= $escaper->escapeUrl($images['tablet']) ?>">
                    <?php endif; ?>
                    <?php if (!empty($images['desktop'])): ?>
                        <img src="<?= $escaper->escapeUrl($images['desktop']) ?>"
                             alt="<?= $escaper->escapeHtmlAttr($altText) ?>"
                             loading="<?= $index === 0 ? 'eager' : 'lazy' ?>"
                             style="width:100%;height:100%;object-fit:cover;display:block;">
                    <?php endif; ?>
                </picture>

                <?php if (!empty($contentHtml)): ?>
                    <div class="panth-banner-content">
                        <div class="panth-banner-content-inner">
                            <?= /* @noEscape */ $contentHtml ?>
                        </div>
                    </div>
                <?php endif; ?>

                <?php if ($hasLink): ?>
                    </a>
                <?php endif; ?>
            </div>
        <?php endforeach; ?>

        <?php if ($showArrows): ?>
            <button type="button" class="panth-banner-arrow panth-banner-arrow--prev" data-action="prev"
                    aria-label="<?= $escaper->escapeHtmlAttr(__('Previous slide')) ?>">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"
                     style="width:var(--banner-arrow-icon-size,20px);height:var(--banner-arrow-icon-size,20px);">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
                </svg>
            </button>
            <button type="button" class="panth-banner-arrow panth-banner-arrow--next" data-action="next"
                    aria-label="<?= $escaper->escapeHtmlAttr(__('Next slide')) ?>">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"
                     style="width:var(--banner-arrow-icon-size,20px);height:var(--banner-arrow-icon-size,20px);">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
                </svg>
            </button>
        <?php endif; ?>
    </div>

    <?php if ($showDots): ?>
        <div class="panth-banner-dots" role="tablist">
            <?php for ($i = 0; $i < $slideCount; $i++): ?>
                <button type="button"
                        class="panth-banner-dot <?= $i === 0 ? 'panth-banner-dot--active' : '' ?>"
                        data-action="goto"
                        data-index="<?= (int)$i ?>"
                        role="tab"
                        aria-label="<?= $escaper->escapeHtmlAttr(__('Go to slide %1', $i + 1)) ?>">
                </button>
            <?php endfor; ?>
        </div>
    <?php endif; ?>
</div>
