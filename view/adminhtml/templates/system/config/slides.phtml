.banner-slides-table-wrapper {
    overflow-x: auto !important;
    overflow-y: visible !important;
    max-width: 100% !important;
    width: 100% !important;
    border: 1px solid #ccc;
    margin-bottom: 10px !important;
    display: block !important;
    position: relative !important;
    -webkit-overflow-scrolling: touch;
}

.banner-slides-table {
    width: auto !important;
    min-width: 2400px !important;
    table-layout: fixed !important;
    border-collapse: collapse !important;
    display: table !important;
}

.banner-slides-table thead th {
    white-space: nowrap !important;
    padding: 8px !important;
    background: #f0f0f0 !important;
    border: 1px solid #ccc !important;
    font-weight: bold !important;
    text-align: left !important;
}

.banner-slides-table tbody td {
    padding: 8px !important;
    border: 1px solid #ccc !important;
    vertical-align: top !important;
}

.banner-slides-table tbody tr {
    display: table-row !important;
}

.banner-slides-table tbody tr.pagination-hidden {
    display: none !important;
}

.banner-slides-table .col-identifier {
    width: 150px !important;
}

.banner-slides-table .col-enabled {
    width: 80px !important;
}

.banner-slides-table .col-desktop_image,
.banner-slides-table .col-tablet_image,
.banner-slides-table .col-mobile_image {
    width: 180px !important;
}

.banner-slides-table .col-content_html {
    width: 450px !important;
    min-width: 450px !important;
}

.banner-slides-table .col-link_url {
    width: 200px !important;
}

.banner-slides-table .col-date_from,
.banner-slides-table .col-date_to {
    width: 150px !important;
}

.banner-slides-table .col-sort_order {
