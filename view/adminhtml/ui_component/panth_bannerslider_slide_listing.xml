<?xml version="1.0" encoding="UTF-8"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">panth_bannerslider_slide_listing.panth_bannerslider_slide_listing_data_source</item>
        </item>
    </argument>
    <settings>
        <buttons>
            <button name="add">
                <url path="*/*/new"/>
                <class>primary</class>
                <label translate="true">Add New Slide</label>
            </button>
        </buttons>
        <spinner>panth_bannerslider_slide_columns</spinner>
        <deps>
            <dep>panth_bannerslider_slide_listing.panth_bannerslider_slide_listing_data_source</dep>
        </deps>
    </settings>

    <dataSource name="panth_bannerslider_slide_listing_data_source" component="Magento_Ui/js/grid/provider">
        <settings>
            <storageConfig>
                <param name="indexField" xsi:type="string">slide_id</param>
            </storageConfig>
            <updateUrl path="mui/index/render"/>
        </settings>
        <aclResource>Panth_BannerSlider::slide</aclResource>
        <dataProvider class="Magento\Framework\View\Element\UiComponent\DataProvider\DataProvider" name="panth_bannerslider_slide_listing_data_source">
            <settings>
                <requestFieldName>slide_id</requestFieldName>
                <primaryFieldName>slide_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>

    <listingToolbar name="listing_top">
        <settings>
            <sticky>true</sticky>
        </settings>
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filterSearch name="fulltext"/>
        <filters name="listing_filters"/>
        <massaction name="listing_massaction">
            <action name="delete">
                <settings>
                    <confirm>
                        <message translate="true">Are you sure you want to delete the selected slides?</message>
                        <title translate="true">Delete Slides</title>
                    </confirm>
                    <url path="panth_bannerslider/slide/massDelete"/>
                    <type>delete</type>
                    <label translate="true">Delete</label>
                </settings>
            </action>
        </massaction>
        <paging name="listing_paging"/>
    </listingToolbar>

    <columns name="panth_bannerslider_slide_columns">
        <selectionsColumn name="ids" sortOrder="0">
            <settings>
                <indexField>slide_id</indexField>
            </settings>
        </selectionsColumn>

        <column name="slide_id" sortOrder="10">
            <settings>
                <filter>textRange</filter>
                <label translate="true">ID</label>
                <sorting>asc</sorting>
            </settings>
        </column>

        <column name="slider_id" component="Magento_Ui/js/grid/columns/select" sortOrder="20">
            <settings>
                <filter>select</filter>
                <options class="Panth\BannerSlider\Model\Config\Source\SliderOptions"/>
                <dataType>select</dataType>
                <label translate="true">Slider</label>
            </settings>
        </column>

        <column name="title" sortOrder="30">
            <settings>
                <filter>text</filter>
                <label translate="true">Title</label>
            </settings>
        </column>

        <column name="is_active" component="Magento_Ui/js/grid/columns/select" sortOrder="40">
            <settings>
                <filter>select</filter>
                <options class="Magento\Config\Model\Config\Source\Yesno"/>
                <dataType>select</dataType>
                <label translate="true">Active</label>
            </settings>
        </column>

        <column name="desktop_image" class="Panth\BannerSlider\Ui\Component\Listing\Column\Thumbnail" component="Magento_Ui/js/grid/columns/thumbnail" sortOrder="50">
            <settings>
                <hasPreview>true</hasPreview>
                <label translate="true">Image</label>
                <sortable>false</sortable>
                <bodyTmpl>ui/grid/cells/thumbnail</bodyTmpl>
            </settings>
        </column>

        <column name="link_url" sortOrder="60">
            <settings>
                <filter>text</filter>
                <label translate="true">Link URL</label>
            </settings>
        </column>

        <column name="sort_order" sortOrder="70">
            <settings>
                <filter>textRange</filter>
                <label translate="true">Sort Order</label>
            </settings>
        </column>

        <column name="store_id" component="Magento_Ui/js/grid/columns/select" sortOrder="80">
            <settings>
                <filter>select</filter>
                <options class="Magento\Store\Ui\Component\Listing\Column\Store\Options"/>
                <dataType>select</dataType>
                <label translate="true">Store View</label>
            </settings>
        </column>

        <column name="created_at" class="Magento\Ui\Component\Listing\Columns\Date" component="Magento_Ui/js/grid/columns/date" sortOrder="90">
            <settings>
                <filter>dateRange</filter>
                <dataType>date</dataType>
                <label translate="true">Created</label>
            </settings>
        </column>

        <actionsColumn name="actions" class="Panth\BannerSlider\Ui\Component\Listing\Column\Actions" sortOrder="200">
            <settings>
                <indexField>slide_id</indexField>
            </settings>
        </actionsColumn>
    </columns>
</listing>
